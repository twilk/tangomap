# ---- Supabase Postgres (project tangomap, ref njlexuaqgzvuylaqgrwm, eu-west-3) ----
# App / serverless -> transaction pooler (6543). Insert your DB password (URL-encode specials).
DATABASE_URL=postgresql://postgres.njlexuaqgzvuylaqgrwm:[YOUR-DB-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres
# Migrations (drizzle-kit) -> session pooler (5432).
DIRECT_URL=postgresql://postgres.njlexuaqgzvuylaqgrwm:[YOUR-DB-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# ---- Teacher allowlist (gates the lesson videos on skill pages) ----
# Mirror of the partykateachers@googlegroups.com members (consumer Google Groups
# have no membership API). Comma/space/semicolon-separated emails. A signed-in
# user whose Google email is listed here sees the lesson videos; everyone else
# sees no trace of them. Update = edit here + in the Vercel env, then redeploy.
TEACHER_EMAILS=
